---
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';
import { hasLink } from '~/utils/erasmusMedia';

/**
 * Carte média unifiée pour la page Erasmus+.
 *
 * Mêmes dimensions quel que soit le média (podcast ou vidéo) : vignette 16:9
 * + pied de carte à hauteur fixe. `h-full` permet d'égaliser les hauteurs dans
 * une grille CSS.
 *
 * Rendu de la vignette (sans recadrage) :
 *  - video  : la miniature YouTube (16:9 natif) remplit la vignette (object-cover).
 *  - podcast: la pochette carrée est centrée (object-contain) sur un fond teinté.
 *  - sans image : fond dégradé + icône générique (fallback cohérent avec les fiches).
 */
interface Props {
  title: string;
  href?: string;
  thumbnail?: string | null;
  kind: 'podcast' | 'video';
  /** Couleur d'accent du volet (fonds teintés + pastille). Défaut : orange marque. */
  accent?: string;
}

const { title, href, thumbnail, kind, accent = 'var(--ootb-orange)' } = Astro.props;

const isPodcast = kind === 'podcast';
// L'accent provient du volet (IA = bleu, Ludopédagogie = mauve) pour une cohérence
// de catégorie ; le type de média reste distingué par la forme de l'icône.
const icon = isPodcast ? 'tabler:headphones' : 'tabler:player-play';

const linked = hasLink(href);
const CardTag = linked ? 'a' : 'div';

// Fond teinté commun (vignette podcast contenue + fallback générique)
const tintBg = `color-mix(in srgb, ${accent} 8%, white)`;
const gradientBg = `linear-gradient(135deg, color-mix(in srgb, ${accent} 16%, white), color-mix(in srgb, ${accent} 6%, white))`;

// Fond de la vignette : transparent quand une miniature vidéo la remplit (object-cover),
// teinté pour les pochettes podcast contenues, dégradé pour le fallback générique.
const vignetteBg = thumbnail && !isPodcast ? 'transparent' : isPodcast ? tintBg : gradientBg;
---

<CardTag
  {...(linked ? { href, target: '_blank', rel: 'noopener noreferrer' } : {})}
  class:list={[
    'group flex h-full flex-col bg-white dark:bg-slate-800 rounded-xl overflow-hidden border border-gray-100 dark:border-slate-700 shadow-sm transition-all',
    linked && 'hover:shadow-md hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2',
  ]}
  style={linked ? `--tw-ring-color: ${accent};` : undefined}
>
  <div
    class="relative aspect-video flex items-center justify-center overflow-hidden dark:bg-slate-700"
    style={`background: ${vignetteBg};`}
  >
    {thumbnail ? (
      <Image
        src={thumbnail}
        alt={`${isPodcast ? 'Pochette du podcast' : 'Miniature de la vidéo'} : ${title}`}
        class:list={[
          'w-full h-full transition-transform duration-500 group-hover:scale-105',
          isPodcast ? 'object-contain p-3' : 'object-cover',
        ]}
        style={isPodcast ? `background: ${tintBg};` : undefined}
        widths={[200, 400]}
        sizes="(max-width: 1024px) 50vw, 25vw"
        aspectRatio="16:9"
        loading="lazy"
      />
    ) : isPodcast ? (
      <Icon
        name={icon}
        class="w-12 h-12"
        style={`color: color-mix(in srgb, ${accent} 55%, white);`}
        aria-hidden="true"
      />
    ) : null}

    {/* Pastille de lecture : seul indicateur pour les vidéos (tous états) ;
        pour les podcasts, uniquement en survol quand une pochette existe. */}
    {(!isPodcast || thumbnail) && (
      <div
        class:list={[
          'flex items-center justify-center transition-opacity',
          thumbnail ? 'absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100' : '',
        ]}
      >
        <span class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center shadow" aria-hidden="true">
          <Icon
            name={isPodcast ? 'tabler:headphones' : 'tabler:player-play-filled'}
            class:list={['w-6 h-6', !isPodcast && 'ml-0.5']}
            style={`color: ${accent};`}
          />
        </span>
      </div>
    )}
  </div>

  <div class="p-3 flex-1 flex flex-col gap-1.5">
    <p class="text-sm font-medium text-gray-800 dark:text-gray-100 line-clamp-2">{title}</p>
    {linked ? (
      <span class="inline-flex items-center gap-1 text-xs font-medium" style={`color: ${accent};`}>
        {isPodcast ? 'Écouter' : 'Regarder'}
        <Icon name="tabler:external-link" class="w-3.5 h-3.5" aria-hidden="true" />
        <span class="sr-only">(s'ouvre dans un nouvel onglet)</span>
      </span>
    ) : (
      <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-400 dark:text-gray-500">
        <Icon name="tabler:clock" class="w-3.5 h-3.5" aria-hidden="true" />
        Bientôt disponible
      </span>
    )}
  </div>
</CardTag>
